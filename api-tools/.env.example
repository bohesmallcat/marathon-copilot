# =============================================================================
# Enterprise API Client - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your tokens:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# --- Email (Daily Briefing) ---
SMTP_HOST=smtp.qq.com
EMAIL_FROM=your_email@qq.com
EMAIL_AUTH_CODE=your_smtp_auth_code

# --- Report Paths ---
REPORTS_DIR=./reports
REPORTS_ONEDRIVE_DIR=

# --- GitHub Enterprise ---
GITHUB_HOST=https://github.example.com
GITHUB_TOKEN=your_github_personal_access_token

# --- COROS Training Hub ---
# Option A: Static token (from browser DevTools → Cookies → CPL-coros-token)
COROS_TOKEN=your_coros_access_token
# Option B: Email + password (auto-login, token auto-refresh)
COROS_EMAIL=your_coros_email
COROS_PASSWORD=your_coros_password
# Region: cn (China) or intl (International)
COROS_REGION=cn
# Push workouts to watch: set to 1 to enable auto-push in run_weekly_plan.sh
# Requires email+password (for userId) or token with known userId
COROS_PUSH_ENABLED=0
