# =============================================================================
# Enterprise API Client - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your tokens:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# --- Email (Daily Briefing) ---
SMTP_HOST=smtp.qq.com
EMAIL_FROM=your_email@qq.com
EMAIL_AUTH_CODE=your_smtp_auth_code

# --- Report Paths ---
REPORTS_DIR=./reports
REPORTS_ONEDRIVE_DIR=

# --- GitHub Enterprise ---
GITHUB_HOST=https://github.example.com
GITHUB_TOKEN=your_github_personal_access_token

# --- COROS Training Hub (Multi-user) ---
# Default user (used when --user not specified)
COROS_DEFAULT_USER=runner_a
# Per-user tokens: COROS_TOKEN_<USER> (from browser DevTools → Cookies → CPL-coros-token)
COROS_TOKEN_RUNNER_A=your_coros_access_token
COROS_REGION_RUNNER_A=cn
COROS_TOKEN_RUNNER_B=your_coros_access_token
COROS_REGION_RUNNER_B=cn
# Per-user email+password (auto-login, token auto-refresh):
# COROS_EMAIL_RUNNER_A=your_coros_email
# COROS_PASSWORD_RUNNER_A=your_coros_password
# Region default: cn (China) or intl (International)
COROS_REGION=cn
# Push workouts to watch: set to 1 to enable auto-push in run_weekly_plan.sh
# Requires email+password (for userId) or token with known userId
COROS_PUSH_ENABLED=0
