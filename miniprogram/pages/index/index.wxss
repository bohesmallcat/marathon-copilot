.hero {
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  color: #FFFFFF;
  text-align: center;
  padding: 60rpx 32rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #E94560;
  margin-top: 12rpx;
  font-weight: 600;
}

.hero-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 16rpx;
}

.profile-header {
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E94560, #C73E54);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.profile-info { flex: 1; }
.profile-name { font-size: 32rpx; font-weight: 600; }
.profile-meta { font-size: 24rpx; color: var(--text-hint); margin-top: 4rpx; }
.profile-edit { color: var(--primary); font-size: 26rpx; }

.setup-card {
  text-align: center;
  padding: 48rpx;
  border: 2rpx dashed var(--border);
  background: #FAFAFA;
}

.setup-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 48rpx;
  margin: 0 auto 16rpx;
}

.setup-text { font-size: 30rpx; font-weight: 600; }
.setup-hint { font-size: 24rpx; color: var(--text-hint); margin-top: 8rpx; }

.action-grid { display: flex; flex-direction: column; gap: 16rpx; }

.action-card { padding: 32rpx; display: flex; flex-direction: row; align-items: center; gap: 24rpx; }

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  flex-shrink: 0;
}

.action-icon-goal { background: linear-gradient(135deg, #3498DB, #2980B9); }
.action-icon-review { background: linear-gradient(135deg, #F39C12, #E67E22); }

.action-title { font-size: 30rpx; font-weight: 600; margin-bottom: 4rpx; }
.action-desc { font-size: 22rpx; color: var(--text-hint); line-height: 1.5; }

.report-item { display: flex; align-items: center; gap: 16rpx; padding: 24rpx 32rpx; }
.report-title { flex: 1; font-size: 28rpx; font-weight: 500; }
.report-meta { font-size: 22rpx; color: var(--text-hint); }
