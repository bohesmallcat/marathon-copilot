.container { padding: 20rpx; }

.race-header {
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  color: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
}
.race-name { font-size: 36rpx; font-weight: bold; }
.race-meta { font-size: 28rpx; opacity: 0.8; margin-top: 12rpx; display: flex; justify-content: space-between; }
.countdown { color: #E94560; font-weight: bold; font-size: 32rpx; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A2E;
  margin-bottom: 20rpx;
}

/* Tab bar */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
}
.tab-active {
  color: #E94560;
  font-weight: bold;
  border-bottom-color: #E94560;
}

/* Form */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; }
.form-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}
.picker-value { color: #333; min-height: 40rpx; line-height: 40rpx; }

.distance-options { display: flex; gap: 16rpx; }
.option-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}
.option-btn.active {
  border-color: #E94560;
  color: #E94560;
  background: rgba(233,69,96,0.05);
}

.btn-primary {
  background: #E94560;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}

/* Plan display */
.plan-phase { margin-bottom: 16rpx; }
.plan-title { font-size: 34rpx; font-weight: bold; color: #1A1A2E; margin-bottom: 20rpx; }
.plan-table { margin-bottom: 20rpx; }
.plan-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.plan-label { width: 200rpx; color: #999; font-size: 26rpx; flex-shrink: 0; }
.plan-value { flex: 1; color: #333; font-size: 26rpx; }
.plan-details {
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 6rpx; font-size: 24rpx; }
.tag-info { background: rgba(26,26,46,0.1); color: #1A1A2E; }
.tag-warning { background: rgba(233,69,96,0.1); color: #E94560; }

/* Meals */
.meal-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.meal-time { width: 200rpx; font-weight: bold; font-size: 26rpx; color: #1A1A2E; flex-shrink: 0; }
.meal-desc { flex: 1; font-size: 26rpx; color: #666; }

/* Checklist */
.checklist { }
.check-item { display: flex; align-items: flex-start; padding: 12rpx 0; }
.check-bullet { color: #E94560; margin-right: 12rpx; font-weight: bold; }
.check-content { flex: 1; }
.check-label { font-weight: bold; font-size: 28rpx; color: #333; }
.check-desc { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }

/* Notes */
.note-item {
  padding: 8rpx 0 8rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  position: relative;
}
.note-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: #E94560;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A2E;
  margin-bottom: 16rpx;
}

.loading-container { text-align: center; padding: 40rpx; }
.loading-text { color: #999; font-size: 28rpx; }
